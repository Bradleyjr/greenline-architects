---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  slug: string;
  category: string;
  location: string;
  year: number;
  heroImage: ImageMetadata | string;
}

const { title, slug, category, location, year, heroImage } = Astro.props;
const isExternal = typeof heroImage === 'string';
---

<article class="project-card" data-category={category}>
  <a href={`/projects/${slug}`} class="project-card__link">
    <div class="project-card__image-wrap">
      {isExternal ? (
        <img
          src={heroImage}
          alt={title}
          class="project-card__image"
          loading="lazy"
          decoding="async"
          width="800"
          height="600"
        />
      ) : (
        <Image
          src={heroImage}
          alt={title}
          class="project-card__image"
          loading="lazy"
          decoding="async"
          widths={[400, 640, 800]}
          sizes="(min-width: 1024px) 50vw, (min-width: 640px) 50vw, 100vw"
          quality={75}
        />
      )}
      <div class="project-card__overlay">
        <span class="project-card__cta">View Project</span>
      </div>
    </div>
    <div class="project-card__info">
      <span class="project-card__category label">{category}</span>
      <h3 class="project-card__title">{title}</h3>
      <p class="project-card__meta">{location} &middot; {year}</p>
    </div>
  </a>
</article>

<style>
  .project-card {
    --card-radius: var(--radius-sm);
  }

  .project-card__link {
    display: block;
  }

  .project-card__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--color-dark-10);
  }

  .project-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .project-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 26, 26, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
  }

  .project-card__cta {
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-light);
    padding: var(--space-2) var(--space-5);
    border: 1px solid var(--color-light);
    transition: background var(--duration-fast), color var(--duration-fast);
  }

  .project-card__link:hover .project-card__image {
    transform: scale(1.04);
  }

  .project-card__link:hover .project-card__overlay {
    opacity: 1;
  }

  .project-card__link:hover .project-card__cta {
    background: var(--color-light);
    color: var(--color-dark);
  }

  .project-card__info {
    padding-top: var(--space-5);
  }

  .project-card__category {
    display: block;
    margin-bottom: var(--space-2);
  }

  .project-card__title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-1);
  }

  .project-card__meta {
    font-size: var(--text-sm);
    color: var(--color-mid);
  }
</style>
