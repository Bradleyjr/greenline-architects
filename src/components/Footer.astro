---
const currentYear = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="footer__inner container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <span class="footer__logo-mark">G</span>
          <span class="footer__logo-text">Greenline Architects</span>
        </a>
        <p class="footer__tagline">
          Thoughtful architecture for lasting places.
        </p>
      </div>

      <div class="footer__columns">
        <div class="footer__col">
          <h3 class="footer__heading">Navigate</h3>
          <ul class="footer__list" role="list">
            <li><a href="/about">About</a></li>
            <li><a href="/projects">Projects</a></li>
            <li><a href="/services">Services</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>

        <div class="footer__col">
          <h3 class="footer__heading">Contact</h3>
          <ul class="footer__list" role="list">
            <li>245 Peachtree Center Ave NE</li>
            <li>Suite 800</li>
            <li>Atlanta, GA 30303</li>
            <li><a href="tel:+14045550140">(404) 555-0140</a></li>
            <li><a href="mailto:hello@greenlinearchitects.com">hello@greenlinearchitects.com</a></li>
          </ul>
        </div>

        <div class="footer__col">
          <h3 class="footer__heading">Follow</h3>
          <ul class="footer__list" role="list">
            <li><a href="#" aria-label="Instagram">Instagram</a></li>
            <li><a href="#" aria-label="LinkedIn">LinkedIn</a></li>
            <li><a href="#" aria-label="Archinect">Archinect</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {currentYear} Greenline Architects. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark);
    color: var(--color-light);
    padding-block: var(--space-11) var(--space-8);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-9);
    padding-bottom: var(--space-9);
    border-bottom: 1px solid rgba(245, 242, 237, 0.12);
  }

  @media (min-width: 1024px) {
    .footer__top {
      grid-template-columns: 1.2fr 2fr;
    }
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    margin-bottom: var(--space-4);
  }

  .footer__logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--color-accent);
    color: var(--color-light);
    font-size: var(--text-base);
  }

  .footer__tagline {
    color: rgba(245, 242, 237, 0.65);
    font-size: var(--text-base);
    max-width: 280px;
  }

  .footer__columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--space-8);
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245, 242, 237, 0.6);
    margin-bottom: var(--space-5);
  }

  .footer__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: rgba(245, 242, 237, 0.75);
  }

  .footer__list a {
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer__list a:hover {
    color: var(--color-accent);
  }

  .footer__bottom {
    padding-top: var(--space-6);
    font-size: var(--text-xs);
    color: rgba(245, 242, 237, 0.55);
  }
</style>
