---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  subtitle?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  fullHeight?: boolean;
  overlay?: boolean;
  lightText?: boolean;
}

const {
  title,
  subtitle,
  image,
  imageAlt = '',
  fullHeight = false,
  overlay = true,
  lightText = false,
} = Astro.props;
---

<section class:list={['hero', { 'hero--full': fullHeight, 'hero--light': lightText }]}>
  {image && (
    <div class="hero__image-wrap">
      <Image
        src={image}
        alt={imageAlt}
        class="hero__image"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        widths={[640, 1024, 1600]}
        sizes="100vw"
        quality={80}
      />
      {overlay && <div class="hero__overlay"></div>}
    </div>
  )}
  <div class="hero__content container">
    {subtitle && <p class="hero__subtitle label">{subtitle}</p>}
    <h1 class="hero__title">{title}</h1>
    <slot />
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: 50vh;
    padding-top: calc(var(--nav-height) + var(--space-9));
    padding-bottom: var(--space-9);
    overflow: hidden;
  }

  .hero--full {
    min-height: 100vh;
    min-height: 100dvh;
  }

  .hero__image-wrap {
    position: absolute;
    inset: 0;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(26, 26, 26, 0.7) 0%,
      rgba(26, 26, 26, 0.3) 50%,
      rgba(26, 26, 26, 0.15) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
  }

  .hero--light .hero__content {
    color: var(--color-light);
  }

  .hero__subtitle {
    margin-bottom: var(--space-4);
  }

  .hero--light .hero__subtitle {
    color: rgba(245, 242, 237, 0.7);
  }

  .hero__title {
    max-width: 14ch;
  }

  @media (min-width: 1024px) {
    .hero {
      padding-bottom: var(--space-11);
    }
  }
</style>
