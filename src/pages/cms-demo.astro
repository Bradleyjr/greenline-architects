---
/**
 * CMS Demo Page
 *
 * This page demonstrates the Storyblok integration pattern.
 * It shows how the same ProjectCard component renders content
 * from either source — proving the migration path is real.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getAllProjects } from '../lib/projects';

const allProjects = await getAllProjects();
const cmsProjects = allProjects.filter(p => p.source === 'storyblok');
const localProjects = allProjects.filter(p => p.source === 'local');
---

<BaseLayout
  title="CMS Integration Demo — Greenline Architects"
  description="Demonstration of Storyblok CMS integration with Astro content collections."
>
  <section class="cms-demo-hero">
    <div class="container">
      <p class="label">Integration Demo</p>
      <h1>Storyblok + Astro</h1>
      <p class="cms-demo-hero__desc">This page demonstrates how the same components render content from two sources — Storyblok's headless CMS and local Astro content collections. The data layer abstracts the source away, so components never need to change.</p>
    </div>
  </section>

  <!-- Architecture Diagram -->
  <section class="section cms-demo-architecture">
    <div class="container">
      <h2>How It Works</h2>
      <div class="cms-demo-flow">
        <div class="cms-demo-flow__step">
          <span class="cms-demo-flow__number">1</span>
          <h3>Data Layer</h3>
          <p><code>src/lib/projects.ts</code> fetches from Storyblok API first. If no CMS content exists, it falls back to local markdown files.</p>
        </div>
        <div class="cms-demo-flow__arrow" aria-hidden="true">&rarr;</div>
        <div class="cms-demo-flow__step">
          <span class="cms-demo-flow__number">2</span>
          <h3>Normalized Shape</h3>
          <p>Both sources return the same <code>NormalizedProject</code> interface — title, slug, category, images, etc.</p>
        </div>
        <div class="cms-demo-flow__arrow" aria-hidden="true">&rarr;</div>
        <div class="cms-demo-flow__step">
          <span class="cms-demo-flow__number">3</span>
          <h3>Same Components</h3>
          <p><code>ProjectCard.astro</code> renders identically regardless of whether data came from Storyblok or local files.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CMS Projects -->
  <section class="section cms-demo-section">
    <div class="container">
      <div class="cms-demo-section__header">
        <span class="cms-demo-badge cms-demo-badge--cms">Storyblok</span>
        <h2>CMS-Sourced Projects ({cmsProjects.length})</h2>
      </div>
      {cmsProjects.length > 0 ? (
        <div class="cms-demo-grid">
          {cmsProjects.map(project => (
            <ProjectCard
              title={project.title}
              slug={project.slug}
              category={project.category}
              location={project.location}
              year={project.year}
              heroImage={project.heroImage as any}
            />
          ))}
        </div>
      ) : (
        <div class="cms-demo-empty">
          <p>No projects in Storyblok yet.</p>
          <p class="text-sm text-mid">To see CMS content here, create stories in your Storyblok space under the <code>projects/</code> folder using the <code>project</code> content type. See the setup guide below.</p>
        </div>
      )}
    </div>
  </section>

  <!-- Local Projects -->
  <section class="section cms-demo-section cms-demo-section--dark">
    <div class="container">
      <div class="cms-demo-section__header">
        <span class="cms-demo-badge cms-demo-badge--local">Local</span>
        <h2>Content Collection Projects ({localProjects.length})</h2>
      </div>
      <div class="cms-demo-grid">
        {localProjects.map(project => (
          <ProjectCard
            title={project.title}
            slug={project.slug}
            category={project.category}
            location={project.location}
            year={project.year}
            heroImage={project.heroImage as any}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Setup Guide -->
  <section class="section cms-demo-guide">
    <div class="container container--narrow">
      <h2>Storyblok Setup Guide</h2>
      <p class="cms-demo-guide__intro">To create CMS-managed projects in your Storyblok space, follow these steps:</p>

      <div class="cms-demo-step">
        <h3>1. Create the "project" content type</h3>
        <p>In your Storyblok space, go to <strong>Block Library</strong> and create a new block called <code>project</code> with these fields:</p>
        <table class="cms-demo-table">
          <thead>
            <tr><th>Field Name</th><th>Type</th><th>Notes</th></tr>
          </thead>
          <tbody>
            <tr><td><code>title</code></td><td>Text</td><td>Project name</td></tr>
            <tr><td><code>category</code></td><td>Single Option</td><td>Values: Residential, Commercial, Civic</td></tr>
            <tr><td><code>location</code></td><td>Text</td><td>e.g. "Atlanta, GA"</td></tr>
            <tr><td><code>year</code></td><td>Number</td><td>Completion year</td></tr>
            <tr><td><code>sqft</code></td><td>Text</td><td>e.g. "38,000"</td></tr>
            <tr><td><code>description</code></td><td>Textarea</td><td>Short project summary</td></tr>
            <tr><td><code>hero_image</code></td><td>Asset</td><td>Main project photo</td></tr>
            <tr><td><code>gallery</code></td><td>Multi-Asset</td><td>Additional photos</td></tr>
            <tr><td><code>body</code></td><td>Richtext</td><td>Full project writeup</td></tr>
            <tr><td><code>featured</code></td><td>Boolean</td><td>Show on homepage</td></tr>
          </tbody>
        </table>
      </div>

      <div class="cms-demo-step">
        <h3>2. Create a "projects" folder</h3>
        <p>In the <strong>Content</strong> section, create a folder called <code>projects</code>. All project stories go inside this folder.</p>
      </div>

      <div class="cms-demo-step">
        <h3>3. Add a project story</h3>
        <p>Inside the <code>projects</code> folder, create a new story using the <code>project</code> content type. Fill in the fields and publish.</p>
      </div>

      <div class="cms-demo-step">
        <h3>4. Rebuild the site</h3>
        <p>Run <code>npm run build</code> or trigger a Vercel deploy. The new project will appear on the site alongside local content collection projects.</p>
      </div>

      <div class="cms-demo-callout">
        <h3>Migration Strategy</h3>
        <p>The data layer in <code>src/lib/projects.ts</code> prioritizes CMS content over local files. As you migrate projects into Storyblok, the local markdown versions are automatically superseded (matched by slug). Once all content lives in the CMS, you can remove the local markdown files entirely.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .cms-demo-hero {
    padding-top: calc(var(--nav-height) + var(--space-11));
    padding-bottom: var(--space-9);
    border-bottom: 1px solid var(--color-border);
  }

  .cms-demo-hero h1 {
    margin-top: var(--space-4);
    margin-bottom: var(--space-5);
  }

  .cms-demo-hero__desc {
    font-size: var(--text-lg);
    color: var(--color-mid);
    max-width: 60ch;
  }

  /* Architecture */
  .cms-demo-architecture h2 {
    margin-bottom: var(--space-8);
  }

  .cms-demo-flow {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .cms-demo-flow {
      grid-template-columns: 1fr auto 1fr auto 1fr;
      align-items: start;
    }
  }

  .cms-demo-flow__step {
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    background: var(--color-light);
  }

  .cms-demo-flow__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--color-accent);
    color: var(--color-light);
    font-size: var(--text-sm);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .cms-demo-flow__step h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }

  .cms-demo-flow__step p {
    font-size: var(--text-sm);
    color: var(--color-mid);
    line-height: 1.7;
  }

  .cms-demo-flow__step code {
    font-size: var(--text-xs);
    background: var(--color-dark-10);
    padding: 2px 6px;
  }

  .cms-demo-flow__arrow {
    display: none;
    font-size: var(--text-2xl);
    color: var(--color-border);
    padding-top: var(--space-8);
  }

  @media (min-width: 1024px) {
    .cms-demo-flow__arrow {
      display: block;
    }
  }

  /* Sections */
  .cms-demo-section__header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .cms-demo-section__header h2 {
    font-size: var(--text-2xl);
  }

  .cms-demo-section--dark {
    background: var(--color-dark);
    color: var(--color-light);
  }

  .cms-demo-section--dark :global(.project-card__title) {
    color: var(--color-light);
  }

  .cms-demo-section--dark :global(.project-card__meta) {
    color: rgba(245, 242, 237, 0.6);
  }

  /* Badge */
  .cms-demo-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .cms-demo-badge--cms {
    background: var(--color-accent);
    color: var(--color-light);
  }

  .cms-demo-badge--local {
    background: rgba(245, 242, 237, 0.15);
    color: var(--color-light);
    border: 1px solid rgba(245, 242, 237, 0.2);
  }

  /* Grid */
  .cms-demo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 640px) {
    .cms-demo-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-7);
    }
  }

  @media (min-width: 1024px) {
    .cms-demo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Empty State */
  .cms-demo-empty {
    padding: var(--space-9);
    border: 2px dashed var(--color-border);
    text-align: center;
  }

  .cms-demo-empty p:first-child {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .cms-demo-empty code {
    font-size: var(--text-xs);
    background: var(--color-dark-10);
    padding: 2px 6px;
  }

  /* Guide */
  .cms-demo-guide h2 {
    margin-bottom: var(--space-4);
  }

  .cms-demo-guide__intro {
    color: var(--color-mid);
    margin-bottom: var(--space-9);
  }

  .cms-demo-step {
    margin-bottom: var(--space-8);
  }

  .cms-demo-step h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .cms-demo-step p {
    color: var(--color-mid);
    line-height: 1.7;
    margin-bottom: var(--space-4);
  }

  .cms-demo-step code {
    font-size: var(--text-sm);
    background: var(--color-dark-10);
    padding: 2px 6px;
  }

  /* Table */
  .cms-demo-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin-top: var(--space-4);
  }

  .cms-demo-table th {
    text-align: left;
    font-weight: 500;
    padding: var(--space-3) var(--space-4);
    border-bottom: 2px solid var(--color-dark);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cms-demo-table td {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-mid);
  }

  .cms-demo-table code {
    font-size: var(--text-xs);
    background: var(--color-dark-10);
    padding: 2px 6px;
  }

  /* Callout */
  .cms-demo-callout {
    margin-top: var(--space-9);
    padding: var(--space-7);
    border-left: 3px solid var(--color-accent);
    background: var(--color-dark-10);
  }

  .cms-demo-callout h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-3);
  }

  .cms-demo-callout p {
    color: var(--color-mid);
    line-height: 1.7;
  }

  .cms-demo-callout code {
    font-size: var(--text-sm);
    background: rgba(26, 26, 26, 0.08);
    padding: 2px 6px;
  }
</style>
