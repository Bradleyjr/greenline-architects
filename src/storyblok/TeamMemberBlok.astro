---
import { storyblokEditable } from '@storyblok/astro';

const { blok } = Astro.props;
---

<div class="team-member" {...storyblokEditable(blok)}>
  {blok.image?.filename && (
    <div class="team-member__image-wrap">
      <img
        src={`${blok.image.filename}/m/400x500/filters:quality(75):format(webp)`}
        alt={blok.image.alt || `Portrait of ${blok.name}`}
        class="team-member__image"
        loading="lazy"
        decoding="async"
        width="400"
        height="500"
      />
    </div>
  )}
  <div class="team-member__info">
    <h3 class="team-member__name">{blok.name}</h3>
    <p class="team-member__role label">{blok.role}</p>
    <p class="team-member__bio">{blok.bio}</p>
  </div>
</div>

<style>
  .team-member__image-wrap {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-dark-10);
    margin-bottom: var(--space-5);
  }

  .team-member__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%);
    transition: filter var(--duration-base) var(--ease-out);
  }

  .team-member:hover .team-member__image {
    filter: grayscale(0%);
  }

  .team-member__name {
    font-size: var(--text-xl);
    margin-bottom: var(--space-1);
  }

  .team-member__role {
    margin-bottom: var(--space-3);
  }

  .team-member__bio {
    font-size: var(--text-sm);
    color: var(--color-mid);
    max-width: 35ch;
  }
</style>
