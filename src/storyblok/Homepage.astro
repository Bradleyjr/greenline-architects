---
import { storyblokEditable, renderRichText } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getFeaturedProjects } from '../lib/projects';

const { blok } = Astro.props;
const featuredProjects = await getFeaturedProjects();
---

<div {...storyblokEditable(blok)}>
  <!-- Hero -->
  <section class="hero hero--full hero--light">
    {blok.hero_image?.filename && (
      <div class="hero__image-wrap">
        <img src={`${blok.hero_image.filename}/m/1600x900/filters:quality(80):format(webp)`} alt={blok.hero_image.alt || ''} class="hero__image" loading="eager" decoding="async" fetchpriority="high" width="1600" height="900" />
        <div class="hero__overlay"></div>
      </div>
    )}
    <div class="hero__content container">
      <p class="hero__subtitle label">{blok.hero_subtitle}</p>
      <h1 class="hero__title">{blok.hero_title}</h1>
      <p class="hero__desc">{blok.hero_description}</p>
      <div class="hero__actions">
        <a href={blok.hero_cta_1_link} class="btn btn--light">{blok.hero_cta_1_text}</a>
        <a href={blok.hero_cta_2_link} class="btn btn--outline btn--outline-light">{blok.hero_cta_2_text}</a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section home-services">
    <div class="container">
      <div class="home-services__header reveal">
        <p class="label">{blok.services_label}</p>
        <h2>{blok.services_heading}</h2>
        <p class="home-services__intro">{blok.services_intro}</p>
      </div>
      <div class="home-services__grid">
        {blok.services?.map((card: any) => (
          <StoryblokComponent blok={card} />
        ))}
      </div>
      <div class="home-services__cta reveal">
        <a href={blok.services_cta_link} class="btn btn--outline">{blok.services_cta_text}</a>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section home-projects">
    <div class="container">
      <div class="home-projects__header reveal">
        <p class="label">{blok.projects_label}</p>
        <h2>{blok.projects_heading}</h2>
      </div>
      <div class="home-projects__grid">
        {featuredProjects.map((project: any, i: number) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <ProjectCard
              title={project.title}
              slug={project.slug}
              category={project.category}
              location={project.location}
              year={project.year}
              heroImage={project.heroImage}
            />
          </div>
        ))}
      </div>
      <div class="home-projects__cta reveal">
        <a href="/projects" class="btn btn--outline">View All Projects</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section home-testimonials">
    <div class="container">
      <div class="home-testimonials__header reveal">
        <p class="label">{blok.testimonials_label}</p>
      </div>
      <div class="home-testimonials__grid">
        {blok.testimonials?.map((t: any) => (
          <StoryblokComponent blok={t} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="home-cta">
    <div class="home-cta__inner container">
      <div class="home-cta__content reveal">
        <h2>{blok.cta_heading}</h2>
        <p>{blok.cta_text}</p>
        <a href={blok.cta_button_link} class="btn btn--accent">{blok.cta_button_text}</a>
      </div>
    </div>
  </section>
</div>

<style>
  /* Hero */
  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: calc(var(--nav-height) + var(--space-8)) 0 var(--space-9);
  }
  .hero--full {
    min-height: 100vh;
    min-height: 100dvh;
  }
  .hero--light {
    color: var(--color-light);
  }
  .hero__image-wrap {
    position: absolute;
    inset: 0;
  }
  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,26,26,0.6) 0%, rgba(26,26,26,0.15) 50%, transparent 100%);
  }
  .hero__content {
    position: relative;
    z-index: 1;
  }
  .hero__subtitle {
    margin-bottom: var(--space-5);
  }
  .hero--light .hero__subtitle {
    color: rgba(245, 242, 237, 0.7);
  }
  .hero__title {
    max-width: 14ch;
  }

  /* Hero extras */
  .hero__desc {
    font-size: var(--text-lg);
    color: rgba(245, 242, 237, 0.8);
    max-width: 48ch;
    margin-top: var(--space-5);
    margin-bottom: var(--space-7);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .btn--outline-light {
    color: var(--color-light);
    border-color: rgba(245, 242, 237, 0.4);
  }

  .btn--outline-light:hover {
    background: var(--color-light);
    color: var(--color-dark);
    border-color: var(--color-light);
  }

  /* Services */
  .home-services__header {
    margin-bottom: var(--space-9);
  }

  .home-services__header h2 {
    margin-top: var(--space-4);
    margin-bottom: var(--space-5);
  }

  .home-services__intro {
    font-size: var(--text-lg);
    color: var(--color-mid);
    max-width: 55ch;
  }

  .home-services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-9);
  }

  @media (min-width: 640px) {
    .home-services__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8);
    }
  }

  .home-services__item {
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .home-services__number {
    font-size: var(--text-xs);
    color: var(--color-accent);
    font-weight: 500;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: var(--space-4);
  }

  .home-services__title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .home-services__desc {
    font-size: var(--text-sm);
    color: var(--color-mid);
    line-height: 1.7;
  }

  /* Featured Projects */
  .home-projects {
    background: var(--color-dark);
    color: var(--color-light);
  }

  .home-projects__header {
    margin-bottom: var(--space-9);
  }

  .home-projects__header .label {
    color: var(--color-accent);
  }

  .home-projects__header h2 {
    margin-top: var(--space-4);
  }

  .home-projects__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-9);
  }

  @media (min-width: 640px) {
    .home-projects__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-7);
    }

    .home-projects__grid > :first-child {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .home-projects__grid {
      grid-template-columns: 1.3fr 1fr;
    }

    .home-projects__grid > :first-child {
      grid-column: auto;
      grid-row: 1 / 3;
    }
  }

  .home-projects :global(.project-card__title),
  .home-projects :global(.project-card__meta) {
    color: rgba(245, 242, 237, 0.7);
  }

  .home-projects :global(.project-card__title) {
    color: var(--color-light);
  }

  .home-projects .btn--outline {
    color: var(--color-light);
    border-color: rgba(245, 242, 237, 0.3);
  }

  .home-projects .btn--outline:hover {
    background: var(--color-light);
    color: var(--color-dark);
  }

  /* Testimonials */
  .home-testimonials__header {
    margin-bottom: var(--space-8);
  }

  .home-testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-9);
  }

  @media (min-width: 1024px) {
    .home-testimonials__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  /* CTA */
  .home-cta {
    background: var(--color-accent);
    color: var(--color-light);
    padding-block: var(--space-section);
  }

  .home-cta h2 {
    margin-bottom: var(--space-5);
  }

  .home-cta p {
    font-size: var(--text-lg);
    color: rgba(245, 242, 237, 0.85);
    margin-bottom: var(--space-7);
    max-width: 50ch;
  }

  .home-cta .btn--accent {
    background: var(--color-dark);
  }

  .home-cta .btn--accent:hover {
    background: var(--color-light);
    color: var(--color-dark);
  }
</style>
