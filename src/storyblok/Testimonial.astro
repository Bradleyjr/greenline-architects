---
import { storyblokEditable } from '@storyblok/astro';

const { blok } = Astro.props;
---

<blockquote class="testimonial" {...storyblokEditable(blok)}>
  <p class="testimonial__quote">&ldquo;{blok.quote}&rdquo;</p>
  <footer class="testimonial__footer">
    <cite class="testimonial__author">{blok.author}</cite>
    <span class="testimonial__role">{blok.role}</span>
  </footer>
</blockquote>

<style>
  .testimonial {
    padding: var(--space-8);
    border-left: 2px solid var(--color-accent);
  }

  .testimonial__quote {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    line-height: 1.4;
    margin-bottom: var(--space-6);
    max-width: 45ch;
  }

  .testimonial__footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .testimonial__author {
    font-style: normal;
    font-weight: 500;
    font-size: var(--text-base);
  }

  .testimonial__role {
    font-size: var(--text-sm);
    color: var(--color-mid);
  }
</style>
