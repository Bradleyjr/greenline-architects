---
import { storyblokEditable } from '@storyblok/astro';
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro';

const { blok } = Astro.props;
---

<div {...storyblokEditable(blok)}>
  <!-- Hero -->
  <section class="hero hero--light">
    {blok.hero_image?.filename && (
      <div class="hero__image-wrap">
        <img src={`${blok.hero_image.filename}/m/1600x900/filters:quality(80):format(webp)`} alt={blok.hero_image.alt || ''} class="hero__image" loading="eager" decoding="async" fetchpriority="high" width="1600" height="900" />
        <div class="hero__overlay"></div>
      </div>
    )}
    <div class="hero__content container">
      <p class="hero__subtitle label">{blok.hero_subtitle}</p>
      <h1 class="hero__title">{blok.hero_title}</h1>
    </div>
  </section>

  <section class="section services-page">
    <div class="container">
      <div class="services-page__intro reveal">
        <h2 class="services-page__heading">{blok.intro_heading}</h2>
        <p class="text-lg">{blok.intro_text}</p>
      </div>
      <div class="services-page__list">
        {blok.services?.map((s: any) => (
          <StoryblokComponent blok={s} />
        ))}
      </div>
      <div class="services-page__cta reveal">
        <div class="services-page__cta-content">
          <h2>{blok.cta_heading}</h2>
          <p>{blok.cta_text}</p>
          <a href={blok.cta_button_link} class="btn btn--primary">{blok.cta_button_text}</a>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  /* Hero */
  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: calc(var(--nav-height) + var(--space-8)) 0 var(--space-9);
  }
  .hero--light {
    color: var(--color-light);
  }
  .hero__image-wrap {
    position: absolute;
    inset: 0;
  }
  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,26,26,0.6) 0%, rgba(26,26,26,0.15) 50%, transparent 100%);
  }
  .hero__content {
    position: relative;
    z-index: 1;
  }
  .hero__subtitle {
    margin-bottom: var(--space-5);
  }
  .hero--light .hero__subtitle {
    color: rgba(245, 242, 237, 0.7);
  }
  .hero__title {
    max-width: 14ch;
  }

  /* Services Page */
  .services-page__intro {
    max-width: var(--max-width-narrow);
    margin-bottom: var(--space-9);
    color: var(--color-mid);
  }

  .services-page__heading {
    font-size: var(--text-3xl);
    color: var(--color-dark);
    margin-bottom: var(--space-5);
  }

  .services-page__list {
    margin-bottom: var(--space-11);
  }

  .services-page__cta {
    padding: var(--space-9);
    background: var(--color-dark-10);
  }

  .services-page__cta h3 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .services-page__cta p {
    font-size: var(--text-lg);
    color: var(--color-mid);
    margin-bottom: var(--space-7);
    max-width: 50ch;
  }
</style>
